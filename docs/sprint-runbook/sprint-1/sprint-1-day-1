#!/usr/bin/env bash
#
# Sprint 1 Day 1 Console-Only Verification Runbook
#
# Purpose:
#   Verify that the StudyBuddy Sprint 1 baseline is aligned with the current
#   Docker + PostgreSQL project setup, isolated Django settings, formatting
#   tools, migrations, and tests.
#
# Execution instructions:
#   1. Run this file from anywhere inside the repository:
#
#        ./docs/sprint-runbook/sprint-1/sprint-1-day-1
#
#   2. If the file is not executable, run:
#
#        chmod +x docs/sprint-runbook/sprint-1/sprint-1-day-1
#
#   3. Docker Desktop or a compatible Docker daemon must be running.
#   4. The script builds/recreates the Docker Compose web container so checks
#      run against the same source and dependency environment as the app.
#
# Expected final receipt:
#   - Repository root verified.
#   - Docker Compose services are healthy/running.
#   - local and test settings import successfully.
#   - Django checks pass for local and test settings.
#   - Migrations are up to date.
#   - Black, isort, and Ruff pass.
#   - Pytest passes with config.settings.test against PostgreSQL.

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
EXPECTED_ROOT_NAME="StudyBuddy-Study-Planner-Project"

section() {
    printf '\n==> %s\n' "$1"
}

run() {
    printf '\n$ %s\n' "$*"
    "$@"
}

section "Verify repository root"
run cd "$PROJECT_ROOT"
printf 'Repository root: %s\n' "$PROJECT_ROOT"

if [[ "$(basename "$PROJECT_ROOT")" != "$EXPECTED_ROOT_NAME" ]]; then
    printf 'Expected repository directory to end with: %s\n' "$EXPECTED_ROOT_NAME" >&2
    printf 'Actual repository directory: %s\n' "$(basename "$PROJECT_ROOT")" >&2
    exit 1
fi

section "Verify required project files"
required_files=(
    ".env.example"
    "README.md"
    "Dockerfile"
    "docker-compose.yml"
    "manage.py"
    "pyproject.toml"
    "pytest.ini"
    "requirements.txt"
    "config/settings/base.py"
    "config/settings/local.py"
    "config/settings/test.py"
    "config/settings/production.py"
    "docs/architecture.md"
    "apps/users/models.py"
    "apps/roles/models.py"
    "apps/dashboard/views.py"
    "tests/test_models.py"
    "tests/test_views.py"
)

for file in "${required_files[@]}"; do
    if [[ ! -f "$PROJECT_ROOT/$file" ]]; then
        printf 'Missing required file: %s\n' "$file" >&2
        exit 1
    fi
    printf 'OK: %s\n' "$file"
done

section "Build and start Docker/PostgreSQL stack"
run docker compose up -d --build
run docker compose ps

section "Verify Python and Django settings imports inside the web container"
run docker compose exec -T web python --version
run docker compose exec -T web python -c "import config.settings.local; print('local settings import OK')"
run docker compose exec -T web python -c "import config.settings.test; print('test settings import OK')"

section "Verify Django settings behaviour"
run docker compose exec -T web python manage.py check --settings=config.settings.local
run docker compose exec -T web python manage.py check --settings=config.settings.test
run docker compose exec -T web python manage.py diffsettings --settings=config.settings.local

section "Verify migrations against PostgreSQL"
run docker compose exec -T web python manage.py makemigrations --check --dry-run --settings=config.settings.test
run docker compose exec -T web python manage.py migrate --noinput
run docker compose exec -T web python manage.py showmigrations --settings=config.settings.local

section "Verify formatting and linting"
run docker compose exec -T web python -m black . --check
run docker compose exec -T web python -m isort . --check-only
run docker compose exec -T web python -m ruff check .

section "Verify tests with isolated test settings"
run docker compose exec -T web env DJANGO_SETTINGS_MODULE=config.settings.test pytest -q

section "Final receipt"
printf 'Repository root verified: %s\n' "$EXPECTED_ROOT_NAME"
printf 'Docker/PostgreSQL stack verified.\n'
printf 'Django local/test settings verified.\n'
printf 'Migrations verified.\n'
printf 'Black, isort, and Ruff verified.\n'
printf 'Pytest verified with config.settings.test.\n'
printf 'Sprint 1 Day 1 verification complete.\n'
