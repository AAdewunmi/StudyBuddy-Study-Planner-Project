DJANGO_SECRET_KEY=change-me-in-local-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Primary database configuration for local, CI, and deployment-style settings.
DATABASE_URL=postgres://studybuddy:studybuddy@db:5432/studybuddy_local

# Docker Compose also uses these values to initialize the PostgreSQL service.
POSTGRES_DB=studybuddy_local
POSTGRES_USER=studybuddy
POSTGRES_PASSWORD=studybuddy
POSTGRES_HOST=db
POSTGRES_PORT=5432